{
  "name": "@nftrs/core",
  "version": "0.3.0",
  "description": "Node.js dependency tracing (a Rust + OXC rewrite of @vercel/nft). Drop-in nodeFileTrace.",
  "keywords": [
    "dependency",
    "napi",
    "nft",
    "node",
    "oxc",
    "rust",
    "trace"
  ],
  "license": "MIT",
  "author": "ubugeeei",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ubugeeei-prod/nftrs.git",
    "directory": "crates/nftrs_napi"
  },
  "files": [
    "cli.js",
    "index.js",
    "index.d.ts"
  ],
  "main": "index.js",
  "types": "index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "napi build --release",
    "build:debug": "napi build"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.0"
  },
  "napi": {
    "binaryName": "nftrs",
    "packageName": "@nftrs/binding",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "bin": {
    "nftrs": "cli.js"
  },
  "optionalDependencies": {
    "@nftrs/binding-darwin-x64": "0.3.0",
    "@nftrs/binding-darwin-arm64": "0.3.0",
    "@nftrs/binding-linux-x64-gnu": "0.3.0",
    "@nftrs/binding-linux-arm64-gnu": "0.3.0",
    "@nftrs/binding-win32-x64-msvc": "0.3.0"
  }
}
